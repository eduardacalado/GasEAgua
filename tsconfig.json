{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@assets/*": ["./assets/*"],
      "@components/*": ["./components/*"],
      "@screens/*": ["./app/screens/*"],
      "@storage/*": ["./storage/*"],
      "@theme/*": ["./theme/*"],
      "@utils/*": ["./utils/*"],
      "@contexts/*": ["./contexts/*"],
      "@libs/*": ["./libs/*"],
      "@hooks/*": ["./hooks/*"],
      "@store/*": ["./store/*"],
      "@routes/*": ["./routes/*"],
      "@types/*": ["./@types/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
